pipeline {
    agent any

    stages {

        stage('Build User Service') {
            steps {
                dir('userservice/user-service') {
                    sh 'chmod +x mvnw'
                    sh './mvnw clean package -DskipTests'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('userservice/user-service') {
                    sh 'docker build -t user-service:${BUILD_NUMBER} .'
                }
            }
        }
    }
}