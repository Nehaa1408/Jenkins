pipeline {
    agent any

    stages {

        stage('Build API Gateway') {
            steps {
                dir('apigateway/apigateway') {
                    sh 'chmod +x mvnw'
                    sh './mvnw clean package -DskipTests'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('apigateway/apigateway') {
                    sh 'docker build -t api-gateway:${BUILD_NUMBER} .'
                }
            }
        }
    }
}